---
import { getRelativeLocaleUrl } from 'astro:i18n';

interface Props {
  theme?: "light" | "dark";
}

const { theme = "light" } = Astro.props;
const currentLocale = Astro.currentLocale || "es";

const pathname = Astro.url.pathname;
let basePath = pathname;
if (basePath.startsWith('/en/') || basePath === '/en') {
  basePath = basePath.replace('/en', '') || '/';
} else if (basePath.startsWith('/fr/') || basePath === '/fr') {
  basePath = basePath.replace('/fr', '') || '/';
}

// Ensure basePath starts with a slash 
if (!basePath.startsWith('/')) basePath = '/' + basePath;

const esUrl = getRelativeLocaleUrl("es", basePath);
const enUrl = getRelativeLocaleUrl("en", basePath);
const frUrl = getRelativeLocaleUrl("fr", basePath);
---

<div
  class="language-switcher flex items-center gap-2 text-sm font-medium"
  data-theme={theme}
>
  <a
    href={esUrl}
    class={`lang-es transition-colors ${
      theme === 'light' 
        ? (currentLocale === 'es' ? 'text-zinc-900 font-bold' : 'text-zinc-400 hover:text-zinc-900') 
        : (currentLocale === 'es' ? 'text-white font-bold' : 'text-zinc-500 hover:text-white')
    }`}
    aria-label="Cambiar a Español"
  >
    ES
  </a>
  <span class={`separator ${theme === 'light' ? 'text-zinc-300' : 'text-zinc-600'}`}>|</span>
  <a
    href={enUrl}
    class={`lang-en transition-colors ${
      theme === 'light' 
        ? (currentLocale === 'en' ? 'text-zinc-900 font-bold' : 'text-zinc-400 hover:text-zinc-900') 
        : (currentLocale === 'en' ? 'text-white font-bold' : 'text-zinc-500 hover:text-white')
    }`}
    aria-label="Switch to English"
  >
    EN
  </a>
  <span class={`separator ${theme === 'light' ? 'text-zinc-300' : 'text-zinc-600'}`}>|</span>
  <a
    href={frUrl}
    class={`lang-fr transition-colors ${
      theme === 'light' 
        ? (currentLocale === 'fr' ? 'text-zinc-900 font-bold' : 'text-zinc-400 hover:text-zinc-900') 
        : (currentLocale === 'fr' ? 'text-white font-bold' : 'text-zinc-500 hover:text-white')
    }`}
    aria-label="Passer au Français"
  >
    FR
  </a>
</div>
