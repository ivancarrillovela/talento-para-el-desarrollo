---
import { getRelativeLocaleUrl } from "astro:i18n";
import { useTranslations } from "../../i18n/ui";
import LanguageSwitcher from "./LanguageSwitcher.astro";

interface Props {
  title: string;
  description?: string;
  subtitle?: string;
}

const { title, description, subtitle } = Astro.props;

const lang = Astro.currentLocale || "es";
const t = useTranslations(lang as any);
const rootHref = getRelativeLocaleUrl(lang, "/");
---

<div class="bg-zinc-900 pt-10 pb-64 relative overflow-hidden">
  <div
    class="absolute top-0 right-0 w-[600px] h-[600px] bg-terracotta-500/20 rounded-full blur-[100px] -translate-y-1/2 translate-x-1/3 pointer-events-none mix-blend-screen"
  >
  </div>
  <div
    class="absolute bottom-0 left-0 w-[500px] h-[500px] bg-zinc-800/50 rounded-full blur-[100px] translate-y-1/3 -translate-x-1/4 pointer-events-none"
  >
  </div>

  <div class="container mx-auto px-6 lg:px-12 relative z-10 text-center">
    <div class="flex flex-row justify-between items-center mb-20 gap-4">
      <a
        href={rootHref}
        class="inline-flex items-center gap-2 text-zinc-400 hover:text-white transition-colors text-sm font-bold uppercase tracking-widest"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="2"
          stroke="currentColor"
          class="w-4 h-4"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"></path>
        </svg>
        {t('nav.backToHome')}
      </a>

      <LanguageSwitcher theme="dark" />
    </div>

    {subtitle && (
      <div class="flex items-center justify-center gap-3 mb-6">
        <span class="w-12 h-[1px] bg-terracotta-500"></span>
        <span class="text-terracotta-500 text-sm font-bold tracking-widest uppercase">
          {subtitle}
        </span>
        <span class="w-12 h-[1px] bg-terracotta-500"></span>
      </div>
    )}

    <h1 class="text-4xl md:text-6xl font-black text-white mb-6 tracking-tight">
      {title}
    </h1>
    {
      description && (
        <p class="text-zinc-400 text-lg md:text-xl leading-relaxed max-w-2xl mx-auto font-light">
          {description}
        </p>
      )
    }
  </div>
</div>
