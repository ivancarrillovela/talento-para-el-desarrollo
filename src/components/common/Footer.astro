---
import { SITE_INFO } from "../../constants";
import { useTranslations } from "../../i18n/ui";
import { getRelativeLocaleUrl } from "astro:i18n";

interface Props {
  variant?: "default" | "mobile";
}

const { variant = "default" } = Astro.props;
const isMobile = variant === "mobile";

const year = new Date().getFullYear();
const lang = Astro.currentLocale || "es";
const t = useTranslations(lang as any);
const rootHref = getRelativeLocaleUrl(lang, "/");

const footerLinks = [
  { label: t('footer.legal'),   href: `${rootHref}aviso-legal` },
  { label: t('footer.privacy'), href: `${rootHref}privacidad` },
  { label: t('footer.cookies'), href: `${rootHref}politica-de-cookies` },
];
---

<footer
  class={isMobile
    ? "mt-auto border-t border-zinc-100 pt-6"
    : "hidden md:block bg-zinc-900 text-zinc-400 py-12 border-t border-zinc-800"}
>
  <div
    class={isMobile
      ? "flex flex-col"
      : "container mx-auto px-6 lg:px-12 grid grid-cols-3 items-center gap-8"}
  >
    {/* Marca */}
    <div class={isMobile ? "" : "text-left"}>
      <h4
        class={isMobile
          ? "text-zinc-900 font-bold text-lg mb-1"
          : "text-white font-bold text-xl mb-2"}
      >
        {SITE_INFO.name}
      </h4>
      <p class={isMobile ? "text-sm text-zinc-400 mb-4" : "text-sm max-w-xs"}>
        {t('footer.slogan')}
      </p>
    </div>

    {/* Copyright */}
    <div
      class={isMobile
        ? "text-xs text-zinc-400 mt-8 order-last"
        : "text-sm text-zinc-600 text-center"}
    >
      &copy; {year} {SITE_INFO.name}. {t('footer.rights')}
    </div>

    {/* Enlaces + redes */}
    <div
      class={isMobile
        ? "flex flex-col gap-4 text-sm text-zinc-500"
        : "flex flex-col items-end gap-4 text-sm"}
    >
      <div
        class={isMobile
          ? "flex flex-wrap gap-x-5 gap-y-2"
          : "flex flex-wrap justify-end gap-6"}
      >
        {
          footerLinks.map((link) => (
            <a
              href={link.href}
              class={
                isMobile
                  ? "hover:text-zinc-900 transition-colors"
                  : "group relative hover:text-white transition-colors py-1"
              }
            >
              {link.label}
              {!isMobile && (
                <span class="absolute bottom-0 left-0 w-full h-0.5 bg-terracotta-500 transform scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left" />
              )}
            </a>
          ))
        }
      </div>
    </div>
  </div>
</footer>
