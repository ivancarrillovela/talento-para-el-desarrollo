---
import { useTranslations } from "../../i18n/ui";

const lang = Astro.currentLocale || "es";
const t = useTranslations(lang as any);
---

<section
  id="como-beneficiarte"
  class="bg-zinc-900 pt-10 pb-16 sm:pt-14 sm:pb-24 lg:pt-24 lg:pb-40 text-white relative overflow-hidden"
>
  <div class="absolute top-0 left-0 w-full h-full opacity-5 pointer-events-none">
    <div class="absolute bottom-[-20%] right-[-10%] w-[600px] h-[600px] rounded-full bg-terracotta-500 blur-[150px]"></div>
  </div>

  <div class="container mx-auto px-6 lg:px-12 relative z-10">
    <div class="max-w-4xl mx-auto text-center mb-16">
      <h2 class="text-terracotta-500 font-bold tracking-widest uppercase text-sm mb-4">
        {t('beneficiarte.label')}
      </h2>
      <h3 class="text-3xl md:text-5xl font-bold leading-tight text-white mb-6">
        {t('beneficiarte.titulo')}
      </h3>
      <p class="text-lg text-zinc-400 leading-relaxed font-light max-w-2xl mx-auto">
        {t('beneficiarte.descripcion')}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12 relative">
      {/* Línea conectora (solo desktop) */}
      <div class="hidden md:block absolute top-12 left-[16%] right-[16%] h-0.5 bg-gradient-to-r from-zinc-800 via-terracotta-500/50 to-zinc-800 z-0"></div>

      {/* Paso 1 */}
      <div class="relative z-10 flex flex-col items-center text-center group">
        <div class="w-24 h-24 bg-zinc-800 rounded-full border-2 border-zinc-700 flex items-center justify-center text-3xl font-bold text-white mb-6 transition-all duration-300 shadow-lg">
          1
        </div>
        <h4 class="text-xl font-bold text-white mb-3">{t('beneficiarte.paso1.titulo')}</h4>
        <p class="text-zinc-400 text-sm leading-relaxed">{t('beneficiarte.paso1.desc')}</p>
      </div>

      {/* Paso 2 */}
      <div class="relative z-10 flex flex-col items-center text-center group">
        <div class="w-24 h-24 bg-zinc-800 rounded-full border-2 border-zinc-700 flex items-center justify-center text-3xl font-bold text-white mb-6 transition-all duration-300 shadow-lg">
          2
        </div>
        <h4 class="text-xl font-bold text-white mb-3">{t('beneficiarte.paso2.titulo')}</h4>
        <p class="text-zinc-400 text-sm leading-relaxed">{t('beneficiarte.paso2.desc')}</p>
      </div>

      {/* Paso 3 */}
      <div class="relative z-10 flex flex-col items-center text-center group">
        <div class="w-24 h-24 bg-zinc-800 rounded-full border-2 border-zinc-700 flex items-center justify-center text-3xl font-bold text-white mb-6 transition-all duration-300 shadow-lg">
          3
        </div>
        <h4 class="text-xl font-bold text-white mb-3">{t('beneficiarte.paso3.titulo')}</h4>
        <p class="text-zinc-400 text-sm leading-relaxed">{t('beneficiarte.paso3.desc')}</p>
      </div>
    </div>

    <div class="mt-16 text-center">
      <a
        href="#contacto"
        class="inline-block px-8 py-4 bg-terracotta-500 hover:bg-terracotta-600 text-white font-bold rounded-sm transition-all duration-300 transform hover:-translate-y-1 shadow-lg hover:shadow-terracotta-500/30"
      >
        {t('beneficiarte.boton')}
      </a>
    </div>
  </div>
</section>
