---
import { getCollection } from "astro:content";
import { formatDate } from "../../utils/date";
import ProjectCard from "../proyectos/ProjectCard.astro";
import { useTranslations } from "../../i18n/ui";
import { getRelativeLocaleUrl } from "astro:i18n";

const lang = Astro.currentLocale || "es";
const t = useTranslations(lang as any);
const proyectosUrl = getRelativeLocaleUrl(lang, "/proyectos");

const proyectosRaw = await getCollection("proyectos");
const proyectos = proyectosRaw
  .sort((a, b) => b.data.fecha.valueOf() - a.data.fecha.valueOf())
  .slice(0, 6);

if (!proyectos || proyectos.length === 0) return null;
---

<section
  id="nuestro-trabajo"
  class="bg-zinc-50 py-16 md:py-24 text-zinc-900 border-b border-zinc-200"
>
  <div class="container mx-auto px-6 lg:px-12">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-16">
      <div class="max-w-2xl">
        <h2 class="text-terracotta-500 font-bold tracking-widest uppercase text-sm mb-2">
          {t('trabajo.label')}
        </h2>
        <h3 class="text-4xl md:text-5xl font-bold mb-6">{t('trabajo.titulo')}</h3>
        <p class="text-zinc-600 text-lg leading-relaxed max-w-xl">
          {t('trabajo.descripcion')}
        </p>
      </div>

      <div class="hidden md:block">
        <a
          href={proyectosUrl}
          class="group inline-flex items-center gap-2 text-zinc-900 font-bold hover:text-terracotta-500 transition-colors"
        >
          {t('trabajo.verTodos')}
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 group-hover:translate-x-1 transition-transform">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3"></path>
          </svg>
        </a>
      </div>
    </div>

    <div class="flex justify-end md:hidden mb-2 items-center gap-1 text-zinc-400 px-6">
      <span class="text-xs font-bold uppercase tracking-widest">{t('trabajo.desliza')}</span>
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 animate-pulse">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path>
      </svg>
    </div>

    <div class="flex overflow-x-auto snap-x snap-mandatory gap-6 pb-8 md:grid md:grid-cols-2 lg:grid-cols-3 md:gap-8 md:pb-0 -mx-6 px-6 md:mx-0 md:px-0 scrollbar-hide items-stretch md:overflow-visible">
      {
        proyectos.map((proyecto, index) => (
          <ProjectCard
            proyecto={proyecto}
            index={index}
            class="min-w-[85vw] md:min-w-0 snap-center h-full border border-zinc-100 md:border-none"
          />
        ))
      }
    </div>

    <div class="mt-8 text-center md:hidden">
      <a
        href={proyectosUrl}
        class="inline-block px-8 py-4 bg-white border border-zinc-200 text-zinc-900 font-bold hover:bg-terracotta-500 hover:text-white hover:border-terracotta-500 transition-all duration-300 rounded-sm shadow-sm"
      >
        {t('trabajo.verTodos')}
      </a>
    </div>
  </div>
</section>
