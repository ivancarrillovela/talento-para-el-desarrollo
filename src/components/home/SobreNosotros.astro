---
// Reset de contenido para la sección Sobre Nosotros
const mision =
  "Nuestra misión es identificar, acompañar y potenciar el talento de jóvenes de entre 22 y 27 años procedentes de países en vías de desarrollo, con especial atención al continente africano. Buscamos perfiles con altas capacidades académicas, compromiso social y vocación de liderazgo, que deseen continuar su formación mediante estudios de posgrado, máster o doctorado en Europa.";

const objetivos = [
  {
    titulo: "Carrera Académica y Docente",
    watermark: "CARRERA",
    descripcion:
      "Identificamos a jóvenes de entre 22 y 27 años procedentes de países en desarrollo, con especial atención a África, para ofrecerles información cualificada sobre las posibilidades de llevar a cabo una exitosa carrera docente e investigadora. Promovemos el desarrollo de trayectorias académicas que generen un impacto real en sus países de origen, contribuyendo al progreso social, económico y educativo de sus comunidades.",
    icon: "M12 14l9-5-9-5-9 5 9 5z M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z",
  },
  {
    titulo: "Redes de Colaboración",
    watermark: "REDES",
    descripcion:
      "Impulsar la creación de redes internacionales de colaboración. Conectamos a estudiantes, investigadores y profesionales de distintos países para fomentar el intercambio de conocimiento y el desarrollo de proyectos conjuntos.",
    icon: "M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z",
  },
  {
    titulo: "Apoyo Financiero",
    watermark: "APOYO",
    descripcion:
      "Ofrecer apoyo financiero adaptado a las necesidades de cada estudiante. Este apoyo puede incluir becas parciales o completas para estudios de máster y doctorado, financiación de proyectos de investigación y ayudas complementarias para facilitar la estancia en Europa.",
    icon: "M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.407 2.651 1M12 8V7m0 1c-1.11 0-2.08.407-2.651 1M12 8V7m0 11v-1m0 1c1.11 0 2.08-.407 2.651-1M12 18V17m0 1c-1.11 0-2.08-.407-2.651-1M12 18V17m-3-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z",
  },
];
---

<section
  id="sobre-nosotros"
  class="relative py-24 lg:py-32 bg-zinc-50 overflow-hidden"
>
  <div class="container mx-auto px-6 lg:px-12 relative z-10 text-left">
    {/* Cabecera de Impacto (Título de Ancho Completo) */}
    <div class="mb-24 lg:mb-32">
      <h2
        class="text-terracotta-500 font-bold tracking-[0.25em] uppercase text-xs mb-10"
      >
        SOBRE NOSOTROS
      </h2>
      <div class="max-w-5xl mb-12">
        <h3 class="text-3xl md:text-5xl lg:text-6xl font-bold leading-tight text-zinc-900 tracking-tighter text-balance">
          <span class="text-terracotta-500">Nuestra misión es</span> identificar, acompañar y potenciar el talento.
        </h3>
      </div>
      <div class="max-w-4xl border-l border-zinc-200 pl-10">
        <p class="text-xl md:text-2xl text-zinc-500 leading-relaxed font-light text-balance mb-8">
          Trabajamos junto a jóvenes de entre 22 y 27 años procedentes de países en vías de desarrollo, con especial atención al continente africano.
        </p>
        <p class="text-xl md:text-2xl text-zinc-500 leading-relaxed font-light text-balance">
          Buscamos perfiles con altas capacidades académicas, compromiso social y vocación de liderazgo, que deseen continuar su formación mediante estudios de posgrado, máster o doctorado en Europa.
        </p>
      </div>
    </div>

    {/* Malla Sincrónica de Objetivos - Scroll Horizontal en Móvil con Grid */}
    <div
      class="grid grid-flow-col auto-cols-[85vw] md:auto-cols-[400px] lg:grid-cols-3 lg:grid-flow-row lg:auto-cols-auto gap-6 lg:gap-12 overflow-x-auto lg:overflow-visible snap-x snap-mandatory pb-12 lg:pb-0 -mx-6 px-6 lg:mx-0 lg:px-0 scrollbar-hide"
    >
      {
        objetivos.map((obj) => (
          <div class="group relative p-10 lg:p-14 bg-white border border-zinc-100 rounded-[2.5rem] overflow-hidden transition-all duration-700 ease-out hover:-translate-y-4 hover:shadow-[0_40px_80px_-15px_rgba(0,0,0,0.06)] text-left flex flex-col h-auto min-w-[85vw] md:min-w-[400px] lg:min-w-0 snap-center lg:snap-align-none">
            
            {/* Marca de Agua */}
            <span class="text-5xl lg:text-[56px] font-bold text-zinc-900/[0.02] absolute top-6 right-6 select-none group-hover:text-terracotta-500/[0.05] transition-colors duration-700 italic tracking-tighter leading-none">
              {obj.watermark}
            </span>

            <div class="relative z-10 mb-10">
              <h4 class="text-2xl lg:text-3xl font-bold text-zinc-900 leading-tight group-hover:text-terracotta-500 transition-colors duration-300">
                {obj.titulo}
              </h4>
            </div>

            <div class="relative z-10 mb-6">
              <div
                class="description-container max-h-[240px] overflow-hidden transition-all duration-500 ease-in-out relative"
              >
                <p
                  class="text-zinc-500 text-lg font-light leading-relaxed group-hover:text-zinc-600 transition-colors duration-500"
                >
                  {obj.descripcion}
                </p>
                <div
                  class="fade-overlay absolute bottom-0 left-0 w-full h-12 bg-gradient-to-t from-white to-transparent pointer-events-none transition-opacity duration-300"
                >
                </div>
              </div>

              <button
                class="read-more-btn mt-4 text-terracotta-500 font-bold text-xs uppercase tracking-widest flex items-center gap-2 hover:gap-3 transition-all duration-300"
              >
                <span>Leer más</span>
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="transition-transform duration-300"
                >
                  <path d="m6 9 6 6 6-6" />
                </svg>
              </button>
            </div>

          </div>
        ))
      }
    </div>

    {/* Indicador de Scroll en Móvil */}
    <div class="flex flex-col items-center gap-6 mt-12 lg:hidden">
      <div
        class="flex items-center gap-3 text-zinc-400 group/scroll pointer-events-none"
      >
        <span class="text-[10px] uppercase tracking-[0.2em] font-bold"
          >Desliza para descubrir más</span
        >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="animate-bounce-x"><path d="M5 12h14M12 5l7 7-7 7"></path></svg
        >
      </div>

      <div id="scroll-dots-sobre" class="flex gap-2">
        <div
          class="w-2 h-2 rounded-full transition-all duration-300 bg-terracotta-500 w-4"
        >
        </div>
        <div
          class="w-2 h-2 rounded-full transition-all duration-300 bg-zinc-200"
        >
        </div>
        <div
          class="w-2 h-2 rounded-full transition-all duration-300 bg-zinc-200"
        >
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  @keyframes bounce-x {
    0%,
    100% {
      transform: translateX(0);
    }
    50% {
      transform: translateX(5px);
    }
  }
  .animate-bounce-x {
    animation: bounce-x 1s infinite;
  }
</style>

<script>
  function setupSobreNosotros() {
    // 1. Scroll Dots Logic
    const container = document.querySelector(
      "#sobre-nosotros .overflow-x-auto",
    );
    const dots = document.querySelectorAll("#scroll-dots-sobre div");

    if (container && dots.length > 0) {
      container.addEventListener("scroll", () => {
        const scrollLeft = container.scrollLeft;
        const width = container.clientWidth;
        const index = Math.round(scrollLeft / width);

        dots.forEach((dot, i) => {
          if (i === index) {
            dot.classList.add("bg-terracotta-500", "w-4");
            dot.classList.remove("bg-zinc-200");
          } else {
            dot.classList.remove("bg-terracotta-500", "w-4");
            dot.classList.add("bg-zinc-200");
          }
        });
      });
    }

    // 2. Read More Toggle Logic
    const readMoreBtns = document.querySelectorAll(".read-more-btn");

    readMoreBtns.forEach((btn) => {
      const container = btn.previousElementSibling;
      const textSpan = btn.querySelector("span");
      const svg = btn.querySelector("svg");
      const overlay = container.querySelector(".fade-overlay");

      // Ocultar botón si el contenido no desborda (opcional pero recomendado)
      if (container.scrollHeight <= 240) {
        btn.style.display = "none";
        overlay.style.display = "none";
      }

      btn.addEventListener("click", () => {
        const isExpanded = container.classList.contains("max-h-none");

        if (isExpanded) {
          container.classList.remove("max-h-none");
          container.classList.add("max-h-[244px]");
          textSpan.textContent = "Leer más";
          svg.style.transform = "rotate(0deg)";
          overlay.style.opacity = "1";
        } else {
          container.classList.add("max-h-none");
          container.classList.remove("max-h-[244px]");
          textSpan.textContent = "Leer menos";
          svg.style.transform = "rotate(180deg)";
          overlay.style.opacity = "0";
        }
      });
    });
  }

  // Ejecutar en carga inicial
  setupSobreNosotros();
  // Ejecutar tras transición de página
  document.addEventListener("astro:after-swap", setupSobreNosotros);
</script>
