---
import { useTranslations } from "../../i18n/ui";
import { getRelativeLocaleUrl } from "astro:i18n";
import HeroCarousel from "./HeroCarousel.astro";

const lang = Astro.currentLocale || "es";
const t = useTranslations(lang as any);
const rootHref = getRelativeLocaleUrl(lang, "/");

const carouselImages = [
  "/images/hero/carrusel1.jpg",
  "/images/hero/carrusel2.jpg",
  "/images/hero/carrusel3.jpg"
];

const carouselPeople = [
  { name: t('hero.students.0.name'), location: t('hero.students.0.location'), bio: t('hero.students.0.bio') },
  { name: t('hero.students.1.name'), location: t('hero.students.1.location'), bio: t('hero.students.1.bio') },
  { name: t('hero.students.2.name'), location: t('hero.students.2.location'), bio: t('hero.students.2.bio') }
];
---

<section
  class="relative w-full min-h-[95vh] bg-zinc-50 flex items-center overflow-hidden"
>
  <div
    class="container mx-auto px-6 lg:px-12 relative z-10 pt-32 pb-12 lg:pt-20"
  >
    <div class="flex flex-col lg:flex-row items-center gap-16 lg:gap-24">
      <div class="w-full lg:w-1/2 space-y-8">
        <div class="flex items-center gap-3">
          <span class="w-12 h-[1px] bg-terracotta-500"></span>
          <span
            class="text-terracotta-500 text-sm font-bold tracking-widest uppercase"
          >
            {t('hero.label')}
          </span>
        </div>

        <h1
          class="text-5xl md:text-6xl lg:text-7xl xl:text-8xl font-bold text-zinc-900 leading-[0.95] tracking-tighter"
        >
          {t('hero.titulo')}
          <br />
          <span class="italic font-serif text-terracotta-500">{t('hero.subtitulo')}</span>
        </h1>

        {/* Carrusel móvil (Entre el título y la descripción) */}
        <div
          data-carousel-wrapper
          class="mobile-carousel block lg:hidden w-full h-[44vh] relative rounded-sm overflow-hidden mt-12 mb-6"
        >
          <HeroCarousel images={carouselImages} alt={t('hero.titulo')} shadow="lg" people={carouselPeople} />

          {/* Capa de información (solo móvil) */}
          <div class="absolute inset-x-0 bottom-0 z-30 px-5 pt-16 pb-5 bg-gradient-to-t from-black/85 via-black/45 to-transparent pointer-events-none">
            <div class="border-l-2 border-terracotta-500 pl-3.5">
              <p data-badge-name class="text-xl font-bold text-white leading-tight tracking-tight"></p>
              <div class="flex items-center gap-1.5 mt-1">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3 h-3 text-terracotta-400 shrink-0">
                  <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"></path>
                  <circle cx="12" cy="9" r="2.5"></circle>
                </svg>
                <span data-badge-location class="text-xs text-zinc-300 font-medium tracking-wide"></span>
              </div>
              <button
                data-open-modal
                class="pointer-events-auto mt-4 inline-flex items-center gap-2 rounded-full bg-terracotta-500 px-4 py-2 text-[11px] font-bold uppercase tracking-widest text-white shadow-lg shadow-black/30 active:scale-95 active:bg-terracotta-600 transition-all group/btn"
              >
                <span>{t('hero.readMore')}</span>
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5 group-hover/btn:translate-x-1 transition-transform">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3"></path>
                </svg>
              </button>
            </div>
          </div>
        </div>

        <p
          class="text-xl text-zinc-600 max-w-lg leading-relaxed font-light border-l-2 border-zinc-200 pl-6"
        >
          {t('hero.descripcion')}
        </p>

        <div class="flex items-center gap-3 md:gap-5 pt-6">
          <a
            href={`${rootHref}#actividades`}
            class="px-6 py-3 md:px-8 md:py-4 bg-zinc-900 text-white text-base md:text-lg font-medium rounded-sm hover:bg-terracotta-500 transition-colors duration-300 shadow-xl shadow-zinc-200 whitespace-nowrap"
          >
            {t('hero.boton')}
          </a>
          <a
            href={`${rootHref}#contacto`}
            class="group flex items-center gap-2 px-3 py-3 md:px-6 md:py-4 text-zinc-900 text-base md:text-lg font-medium hover:text-terracotta-500 transition-colors duration-300 whitespace-nowrap"
          >
            {t('hero.botonSecundario')}
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="2"
              stroke="currentColor"
              class="w-4 h-4 md:w-5 md:h-5 group-hover:translate-x-2 transition-transform"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3"></path>
            </svg>
          </a>
        </div>
      </div>

      <div
        data-carousel-wrapper
        class="hidden lg:block w-full lg:w-1/2 relative h-[60vh] lg:h-[80vh] mt-10"
      >
        <HeroCarousel images={carouselImages} alt={t('hero.titulo')} shadow="2xl" people={carouselPeople} />
        <div
          class="absolute bottom-10 -left-10 z-20 bg-white p-6 shadow-xl max-w-xs hidden md:block border-l-4 border-terracotta-500"
        >
          <p data-badge-name class="text-2xl font-bold text-zinc-900"></p>
          <p data-badge-location class="text-sm text-zinc-400 mt-1"></p>
          <button
            class="mt-4 text-xs font-semibold uppercase tracking-widest text-terracotta-500 hover:text-terracotta-900 transition-colors cursor-pointer group"
            data-open-modal
          >
            <span class="group-hover:underline">{t('hero.readMore')}</span>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 inline-block ml-1 group-hover:translate-x-1 transition-transform">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3"></path>
            </svg>
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Modal de estudiante -->
  <dialog
    id="student-modal"
    class="p-0 bg-transparent backdrop:bg-zinc-950/70 backdrop:backdrop-blur-xl focus:outline-none"
  >
    <div class="bg-white max-w-xl w-[90vw] rounded-[1.5rem] sm:rounded-[2.5rem] shadow-2xl border border-zinc-100 overflow-hidden">
      <!-- Cabecera con botón cerrar -->
      <div class="flex items-center justify-between px-6 sm:px-8 pt-6 sm:pt-8 pb-0">
        <span class="text-terracotta-500 font-bold tracking-[0.35em] uppercase text-[9px] sm:text-[10px] opacity-60">
          {t('hero.label')}
        </span>
        <button
          id="close-student-modal"
          class="w-8 h-8 sm:w-10 sm:h-10 rounded-full bg-zinc-100 flex items-center justify-center text-zinc-400 hover:text-zinc-900 hover:bg-zinc-200 transition-all duration-500 hover:rotate-90"
          aria-label="Cerrar"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4">
            <path d="M18 6L6 18M6 6l12 12"></path>
          </svg>
        </button>
      </div>

      <!-- Cuerpo: foto carnet + datos -->
      <div class="flex items-stretch gap-5 sm:gap-8 px-6 sm:px-8 pt-5 sm:pt-6 pb-6 sm:pb-8">
        <!-- Foto tipo carnet -->
        <div class="shrink-0 self-stretch">
          <div class="w-24 sm:w-32 h-full min-h-[8rem] rounded-xl sm:rounded-2xl overflow-hidden border border-zinc-100 shadow-md bg-zinc-50">
            <img
              id="modal-image"
              src=""
              alt=""
              aria-hidden="true"
              class="w-full h-full object-cover object-top"
              onerror="this.onerror=null;this.src='/images/no_image.jpg';"
            />
          </div>
        </div>

        <!-- Información -->
        <div class="flex-1 min-w-0 flex flex-col justify-between gap-4">
          <div class="space-y-1">
            <h3 id="modal-name" class="text-lg sm:text-2xl font-bold text-zinc-900 tracking-tight leading-tight"></h3>
            <div class="flex items-center gap-1.5">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3 h-3 text-terracotta-500 shrink-0">
                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"></path>
                <circle cx="12" cy="9" r="2.5"></circle>
              </svg>
              <span id="modal-location" class="text-[11px] sm:text-xs text-zinc-400 font-medium truncate tracking-wide"></span>
            </div>
          </div>

          <!-- Testimonio -->
          <div class="relative flex-1">
            <span class="absolute -top-2 -left-1 text-4xl sm:text-5xl font-serif text-terracotta-500 leading-none select-none opacity-40">"</span>
            <p id="modal-bio" class="text-zinc-500 text-xs sm:text-sm leading-relaxed font-light italic pt-3 pl-3"></p>
          </div>

          <div class="pt-3 border-t border-zinc-100 flex items-center gap-2">
            <div class="w-1.5 h-1.5 rounded-full bg-terracotta-500 shrink-0"></div>
            <span class="text-[10px] font-semibold text-zinc-400 tracking-widest uppercase">Talento para el Desarrollo</span>
          </div>
        </div>
      </div>
    </div>
  </dialog>
</section>

<style>
  dialog::backdrop {
    animation: fadeIn 0.4s ease-out;
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  dialog[open] > div {
    animation: slideInUpPremium 0.55s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes slideInUpPremium {
    from {
      transform: scale(0.97) translateY(40px);
      opacity: 0;
    }
    to {
      transform: scale(1) translateY(0);
      opacity: 1;
    }
  }

  /* En móvil, los puntos del carrusel se mueven arriba para no tapar la info */
  .mobile-carousel :global(.carousel-dots) {
    bottom: auto;
    top: 1rem;
    left: auto;
    right: 1rem;
    transform: none;
  }
</style>

<script define:vars={{ carouselPeople, carouselImages }}>
  const modal = document.getElementById("student-modal");
  const closeModalBtn = document.getElementById("close-student-modal");
  const modalImage = document.getElementById("modal-image");
  const modalName = document.getElementById("modal-name");
  const modalLocation = document.getElementById("modal-location");
  const modalBio = document.getElementById("modal-bio");

  function openModal(index) {
    const student = carouselPeople?.[index];
    if (student) {
      if (modalName) modalName.textContent = student.name;
      if (modalLocation) modalLocation.textContent = student.location;
      if (modalBio) modalBio.textContent = student.bio || 'Información próximamente...';
    }
    if (modalImage) {
      modalImage.src = carouselImages?.[index] || '';
      modalImage.alt = student?.name || '';
    }
    modal?.showModal();
  }

  function closeModal() {
    modal?.close();
  }

  // Cada botón "Leer más" abre el testimonio del estudiante visible en SU carrusel
  document.querySelectorAll("[data-open-modal]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const index = parseInt(btn.dataset.studentIndex || "0", 10);
      openModal(index);
    });
  });

  closeModalBtn?.addEventListener("click", closeModal);

  modal?.addEventListener("click", (e) => {
    if (e.target === modal) closeModal();
  });

  // Cada carrusel actualiza solo el badge/capa y el botón de su propio contenedor
  window.addEventListener("carouselIndexChange", (event) => {
    const { index, carouselId } = event.detail;
    const person = carouselPeople?.[index];
    if (!person) return;

    const carouselEl = document.querySelector(`[data-carousel-id="${carouselId}"]`);
    const wrapper = carouselEl?.closest("[data-carousel-wrapper]");
    if (!wrapper) return;

    wrapper.querySelectorAll("[data-badge-name]").forEach((el) => {
      el.textContent = person.name;
    });
    wrapper.querySelectorAll("[data-badge-location]").forEach((el) => {
      el.textContent = person.location;
    });
    wrapper.querySelectorAll("[data-open-modal]").forEach((btn) => {
      btn.dataset.studentIndex = String(index);
    });
  });
</script>
