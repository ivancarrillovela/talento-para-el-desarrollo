---
import { useTranslations } from "../../i18n/ui";

const lang = Astro.currentLocale || "es";
const t = useTranslations(lang as any);

const valores = [
  { key: 'compromiso'    },
  { key: 'empatia'       },
  { key: 'integridad'    },
  { key: 'innovacion'    },
  { key: 'liderazgo'     },
  { key: 'colaboracion'  },
  { key: 'excelencia'    },
  { key: 'sostenibilidad'},
  { key: 'anticorrupcion'},
] as const;
---

<section
  id="valores"
  class="bg-zinc-950 pt-10 pb-16 sm:pt-14 sm:pb-24 lg:pt-24 lg:pb-40 text-white relative overflow-hidden"
>
  {/* Gradientes de fondo mejorados */}
  <div class="absolute top-0 left-0 w-full h-full pointer-events-none">
    <div class="absolute top-[-10%] left-[-5%] w-[500px] h-[500px] rounded-full bg-terracotta-500/10 blur-[120px]"></div>
    <div class="absolute bottom-[-10%] right-[-5%] w-[400px] h-[400px] rounded-full bg-terracotta-600/5 blur-[100px]"></div>
  </div>

  <div class="container mx-auto px-6 lg:px-12 relative z-10">
    <div class="max-w-2xl">
      <h2 class="text-terracotta-500 font-bold tracking-widest uppercase text-sm mb-6 sm:mb-8">
        {t('valores.label')}
      </h2>
    </div>
    <div class="flex flex-col md:flex-row justify-between items-start mb-8 lg:mb-12 gap-10 border-b border-white/5 pb-4 lg:pb-6">
      <div class="max-w-2xl">
        <h3 class="text-3xl sm:text-5xl lg:text-7xl font-bold leading-tight text-white tracking-tighter text-balance">
          {t('valores.titulo')}
        </h3>
      </div>
      <p class="text-xl md:text-2xl text-zinc-400 leading-relaxed font-light max-w-md text-left md:text-right text-pretty md:mt-4 lg:mt-6">
        {t('valores.descripcion')}
      </p>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-3 gap-3 md:gap-6 [&>*:last-child:nth-child(odd)]:col-span-2 lg:[&>*:last-child:nth-child(odd)]:col-span-1">
      {
        valores.map((v) => (
          <div class="group relative p-5 md:p-6 bg-white/[0.02] backdrop-blur-md border border-white/[0.05] hover:border-terracotta-500/30 rounded-xl lg:rounded-2xl transition-all duration-500 lg:hover:-translate-y-1 hover:bg-white/[0.04] hover:shadow-[0_20px_40px_-15px_rgba(0,0,0,0.3)] flex flex-col items-start gap-4">
            {/* Overlay de gradiente sutil al hover */}
            <div class="absolute inset-0 bg-gradient-to-br from-terracotta-500/5 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700 rounded-xl lg:rounded-2xl" />
            
            <div class="relative z-10 shrink-0 max-w-full">
              <div class="px-2 py-1.5 sm:px-3 sm:py-1.5 md:px-5 md:py-2.5 bg-zinc-900/80 border border-white/10 rounded-lg md:rounded-xl flex items-center justify-center text-white group-hover:border-terracotta-500 group-hover:text-terracotta-500 transition-all duration-500 shadow-2xl relative overflow-hidden max-w-full">
                <div class="absolute inset-0 bg-gradient-to-tr from-terracotta-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500" />
                <h4 class="relative z-10 text-[11px] min-[380px]:text-xs sm:text-sm md:text-lg font-bold tracking-wider sm:tracking-widest uppercase mb-0 text-center break-words hyphens-auto">
                  {t(`valor.${v.key}.titulo` as any)}
                </h4>
              </div>
            </div>
            
            <div class="relative z-10 w-full">
              <p class="text-base sm:text-lg text-zinc-500 leading-relaxed group-hover:text-zinc-300 transition-all duration-500 line-clamp-4 font-light text-pretty">
                {t(`valor.${v.key}.descripcion` as any)}
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
