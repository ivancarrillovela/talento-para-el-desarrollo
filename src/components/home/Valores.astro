---
import { useTranslations } from "../../i18n/ui";

const lang = Astro.currentLocale || "es";
const t = useTranslations(lang as any);

const valores = [
  'compromiso', 'empatia', 'integridad', 'innovacion', 'liderazgo',
  'colaboracion', 'excelencia', 'sostenibilidad', 'anticorrupcion',
] as const;
---

<section
  id="valores"
  class="bg-zinc-950 pt-10 pb-16 sm:pt-14 sm:pb-24 lg:pt-24 lg:pb-40 text-white relative overflow-hidden"
>
  <div class="absolute top-[-10%] left-[-5%] w-[700px] h-[700px] rounded-full bg-terracotta-500/8 blur-[160px] pointer-events-none"></div>
  <div class="absolute bottom-0 right-[-10%] w-[500px] h-[500px] rounded-full bg-zinc-800/30 blur-[120px] pointer-events-none"></div>

  <div class="container mx-auto px-6 lg:px-12 relative z-10">

    <!-- Cabecera -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12 lg:mb-16">
      <div>
        <p class="text-terracotta-500 text-sm font-bold tracking-widest uppercase mb-4">
          {t('valores.label')}
        </p>
        <h2 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white tracking-tighter leading-none max-w-lg">
          {t('valores.titulo')}
        </h2>
      </div>
      <p class="text-zinc-400 text-base sm:text-lg leading-relaxed font-light max-w-sm md:text-right text-pretty">
        {t('valores.descripcion')}
      </p>
    </div>

    <!-- Grid de valores -->
    <div class="grid grid-cols-2 lg:grid-cols-3 gap-3 md:gap-4">
      {valores.map((key) => (
        <div class="group relative bg-white/[0.03] border border-white/[0.07] rounded-2xl p-5 sm:p-7 overflow-hidden flex flex-col gap-5 hover:border-white/[0.14] hover:bg-white/[0.05] transition-all duration-500 [&:nth-last-child(1):nth-child(odd)]:col-span-2 lg:[&:nth-last-child(1):nth-child(odd)]:col-span-1">

          <!-- Barra terracota animada en la parte superior -->
          <div class="absolute top-0 left-0 right-0 h-[2px] bg-terracotta-500 origin-left scale-x-0 group-hover:scale-x-100 transition-transform duration-500 ease-[cubic-bezier(0.16,1,0.3,1)]"></div>

          <!-- Título -->
          <h3 class="text-base sm:text-lg lg:text-xl font-bold text-zinc-200 group-hover:text-white tracking-tight leading-snug transition-colors duration-300">
            {t(`valor.${key}.titulo` as any)}
          </h3>

          <!-- Descripción -->
          <p class="text-[11px] sm:text-xs lg:text-sm text-zinc-600 group-hover:text-zinc-400 leading-relaxed font-light transition-colors duration-300">
            {t(`valor.${key}.descripcion` as any)}
          </p>

        </div>
      ))}
    </div>

  </div>
</section>
