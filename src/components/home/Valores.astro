---
import { useTranslations } from "../../i18n/ui";

const lang = Astro.currentLocale || "es";
const t = useTranslations(lang as any);

const valores = [
  { key: 'compromiso'    },
  { key: 'empatia'       },
  { key: 'integridad'    },
  { key: 'innovacion'    },
  { key: 'liderazgo'     },
  { key: 'colaboracion'  },
  { key: 'excelencia'    },
  { key: 'sostenibilidad'},
  { key: 'anticorrupcion'},
] as const;
---

<section
  id="valores"
  class="bg-zinc-900 py-20 lg:py-24 text-white relative overflow-hidden"
>
  <div class="absolute top-0 left-0 w-full h-full opacity-5 pointer-events-none">
    <div class="absolute top-[-20%] left-[-10%] w-[600px] h-[600px] rounded-full bg-terracotta-500 blur-[150px]"></div>
  </div>

  <div class="container mx-auto px-6 lg:px-12 relative z-10">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-16 md:mb-20 gap-8 border-b border-zinc-800 pb-10">
      <div class="max-w-xl">
        <h2 class="text-terracotta-500 font-bold tracking-widest uppercase text-sm mb-4">
          {t('valores.label')}
        </h2>
        <h3 class="text-3xl md:text-5xl font-bold leading-tight text-white">
          {t('valores.titulo')}
        </h3>
      </div>
      <p class="text-lg text-zinc-400 leading-relaxed font-light max-w-lg text-left md:text-right">
        {t('valores.descripcion')}
      </p>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-3 gap-3 md:gap-6 [&>*:last-child:nth-child(odd)]:col-span-2 lg:[&>*:last-child:nth-child(odd)]:col-span-1">
      {
        valores.map((v) => (
          <div class="group relative p-4 md:p-6 bg-zinc-800/50 border border-zinc-800 hover:border-terracotta-500/50 rounded-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-2xl hover:shadow-terracotta-500/10 flex flex-col md:flex-row items-start gap-3 md:gap-4">
            <div class="absolute top-0 left-0 w-full h-full bg-gradient-to-br from-terracotta-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none rounded-sm" />
            <div class="relative z-10 shrink-0">
              <div class="w-10 h-10 md:w-12 md:h-12 bg-zinc-900 border border-zinc-700 rounded-full flex items-center justify-center text-lg md:text-xl group-hover:border-terracotta-500 group-hover:text-terracotta-500 transition-colors duration-300 shadow-lg">
                {t(`valor.${v.key}.icono` as any)}
              </div>
            </div>
            <div class="relative z-10 w-full">
              <h4 class="text-base md:text-xl font-bold mb-1 md:mb-2 text-white group-hover:text-terracotta-500 transition-colors duration-300 leading-tight">
                {t(`valor.${v.key}.titulo` as any)}
              </h4>
              <p class="text-xs md:text-sm text-zinc-400 leading-relaxed group-hover:text-zinc-300 transition-colors line-clamp-3 md:line-clamp-none">
                {t(`valor.${v.key}.descripcion` as any)}
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
